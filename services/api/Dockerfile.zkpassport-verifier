# syntax=docker/dockerfile:1.7

FROM oven/bun:1.3.10

WORKDIR /app/services/api

COPY zkpassport-verifier-runtime/package.json zkpassport-verifier-runtime/bun.lock ./
RUN bun install --frozen-lockfile --production

COPY api/scripts ./scripts
COPY api/src ./src

ENV HOST=0.0.0.0
ENV ZKPASSPORT_VERIFIER_PORT=8794
EXPOSE 8794

CMD ["bun", "run", "scripts/zkpassport-verifier-service.ts"]
