{
  "name": "@pirate/api-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:worker": "wrangler dev --port 8787",
    "dev:local-sqlite": "bun run scripts/serve-local.ts",
    "dev": "bun run dev:worker",
    "local:reset": "bun run scripts/reset-local-sqlite.ts",
    "bruno:prepare:local-sqlite": "bun run scripts/prepare-bruno-local.ts",
    "bruno:test:local-sqlite": "cd bruno && ../node_modules/.bin/bru run . -r --env local --tests-only",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy",
    "deploy": "bun run deploy:production",
    "secrets:list:staging": "wrangler secret list --env staging",
    "secrets:sync:staging": "../../../scripts/sync-wrangler-api-secrets.sh --env-file .env.staging --wrangler-env staging",
    "check": "tsc --noEmit",
    "test": "bun test",
    "mint:dev-jwt": "bun run scripts/mint-dev-jwt.ts",
    "local:seed": "bun run scripts/seed-local-community.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@neondatabase/serverless": "^1.0.2",
    "@piplabs/cdr-contracts": "file:../../../../cdr-sdk/packages/contracts",
    "@piplabs/cdr-crypto": "file:../../../../cdr-sdk/packages/crypto",
    "@pirate/api-contracts": "file:../contracts",
    "@privy-io/node": "^0.11.0",
    "hono": "^4.8.5",
    "jose": "^6.2.2",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@usebruno/cli": "3.2.2",
    "@cloudflare/workers-types": "^4.20260405.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.13.2"
  }
}
